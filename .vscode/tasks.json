{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "qmake: 生成 Makefile",
      "type": "shell",
      "command": "C:/Qt/6.10.2/mingw_64/bin/qmake.exe",
      "args": [
        "ParkingSystem.pro",
        "-spec", "win32-g++",
        "QMAKE_CXX=C:/Qt/Tools/mingw1310_64/bin/g++.exe",
        "QMAKE_CC=C:/Qt/Tools/mingw1310_64/bin/gcc.exe",
        "QMAKE_LINK=C:/Qt/Tools/mingw1310_64/bin/g++.exe",
        "CONFIG+=debug",
        "CONFIG+=qml_debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "make: 编译 (Debug)",
      "type": "shell",
      "command": "C:/Qt/Tools/mingw1310_64/bin/mingw32-make.exe",
      "args": [
        "-f", "Makefile.Debug",
        "-j4"
      ],
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": ["qmake: 生成 Makefile"]
    },
    {
      "label": "make: 清理",
      "type": "shell",
      "command": "C:/Qt/Tools/mingw1310_64/bin/mingw32-make.exe",
      "args": [
        "-f", "Makefile.Debug",
        "clean"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "qmake + make: 完整重建 (Debug)",
      "dependsOrder": "sequence",
      "dependsOn": ["make: 清理", "qmake: 生成 Makefile", "make: 编译 (Debug)"],
      "problemMatcher": ["$gcc"],
      "group": "build"
    }
  ]
}
